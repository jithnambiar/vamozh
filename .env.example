# GEMINI_API_KEY: Required for Gemini AI API calls.
# Obtain from Google AI Studio (https://aistudio.google.com)
# In Vercel: Set as Environment Variable in Project Settings.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Example in production: "https://vamozhi.vercel.app" or "https://vamozhi.com"
APP_URL="https://vamozhi.com"

# OPTIONAL: CLOUD DATABASE PERSISTENCE FOR VERCEL
# Vamozhi automatically uses high-speed in-memory database seeded with default collections out of the box.
# If you want persistent cloud database across serverless re-deployments, add ANY of the following:

# Option A: Vercel KV / Upstash Redis
# KV_REST_API_URL="https://your-kv-db.upstash.io"
# KV_REST_API_TOKEN="your_upstash_redis_token"
# UPSTASH_REDIS_REST_URL="https://your-kv-db.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"

# Option B: PostgreSQL / Supabase / Neon
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
